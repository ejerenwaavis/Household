# Frontend API Configuration
# Leave this unset for local development so the app can use the Vite /api proxy.
# VITE_API_URL=/api

# ─── PRODUCTION (Namecheap) ──────────────────────────────────────────────────
# Set this only in your production build environment.
# If not set, the app falls back to /api (Apache reverse proxy).
# VITE_API_URL=https://api.aceddivision.com/api
